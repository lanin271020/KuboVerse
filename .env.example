# Copie este arquivo para ".env.local" e preencha com os valores do seu
# projeto Supabase (Project Settings > API no painel do supabase.com).
#
# NEXT_PUBLIC_* fica exposto ao navegador — nunca coloque a service role key aqui.

# URL do projeto Supabase (ex.: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon/public key — usada no navegador, protegida pelas políticas de RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service role key — NUNCA expor ao cliente. Usada apenas em código de servidor
# (Route Handlers/Server Actions) quando for necessário ignorar RLS de forma
# controlada. Opcional nesta etapa; deixe em branco se não for usar.
SUPABASE_SERVICE_ROLE_KEY=

# URL pública e definitiva do site em produção (sem "/" no final), ex.:
# https://kuboverse.com.br — usada para montar: metadataBase (SEO/Open
# Graph), sitemap.xml, robots.txt e os links de redirecionamento de
# e-mail de confirmação/recuperação de senha e de login com Google (ver
# services/auth.ts). Sem essa variável em produção, o app cai de volta no
# cabeçalho "Host" da requisição para montar esses links — que pode ser
# manipulado por quem faz a requisição, então é importante configurar
# isto antes do lançamento. Em dev, pode deixar em branco (usa
# http://localhost:3000).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
